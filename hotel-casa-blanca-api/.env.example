# ============================================================================
#  Hotel Casa Blanca API - variables de entorno
#  Copia este archivo a .env y rellena los valores reales.
#  NUNCA subas .env al repositorio (ya esta en .gitignore).
# ============================================================================

# ---- App ----
APP_NAME="Hotel Casa Blanca API"
ENVIRONMENT=development            # development | production
API_V1_PREFIX=/api/v1
# URL publica del backend (la usa MP para back_urls y notification_url).
# En emulador Android la app llega por 10.0.2.2; MP necesita una URL alcanzable
# desde internet en produccion (o un tunel tipo ngrok en pruebas de webhook).
API_BASE_URL=http://10.0.2.2:8000/api/v1
TZ=America/Lima

# ---- Base de datos (async / asyncpg) ----
# El host "db" es el nombre del servicio en docker-compose.
POSTGRES_USER=hotel
POSTGRES_PASSWORD=hotel_pass_cambiar
POSTGRES_DB=hotel
DATABASE_URL=postgresql+asyncpg://hotel:hotel_pass_cambiar@db:5432/hotel

# ---- JWT ----
# Genera un secreto fuerte, p. ej.:  openssl rand -hex 32
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- Google Sign-In (POST /auth/google) ----
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com

# ---- Pagos ----
# fake = pasarela simulada que sirve el propio backend (demo local sin internet).
# Mercado Pago real exige una URL publica para el webhook.
PAGO_PROVEEDOR=fake

# ---- Mercado Pago (Checkout Pro - Opcion A) ----
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxx-xxxxxxxxx
MP_WEBHOOK_SECRET=tu_secret_de_webhook_de_mercado_pago
MP_CURRENCY=PEN
MP_API_BASE=https://api.mercadopago.com

# ---- CORS ----
# Origenes permitidos separados por coma (para el front web, si aplica).
CORS_ORIGINS=*
